# =============================================================================
# SECRETS TEMPLATE — safe to commit (placeholders only)
# =============================================================================
# Local setup:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   Fill in real values in secrets.toml (that file is gitignored).
#
# Streamlit Community Cloud (public deploy):
#   Repo → Settings → Secrets → paste this structure with REAL values.
#   Password stays on Streamlit servers — never in your public GitHub repo.
# =============================================================================

# RECOMMENDED: separate fields (password not embedded in one URI string)
MONGO_USERNAME = "your_atlas_username"
MONGO_PASSWORD = "your_atlas_password"
MONGO_CLUSTER = "cluster0.xxxxx.mongodb.net"
MONGO_DB = "airbnb"
MONGO_COLLECTION = "listings"

# ALTERNATIVE: single URI (do NOT commit the real URI to GitHub)
# MONGO_URI = "mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/airbnb?retryWrites=true&w=majority"
